# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/opener_dev
# For local testing outside docker compose (if running tests directly on host pointing to localhost port 5432)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opener_dev

# Last.fm API Credentials
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_API_SECRET=your_lastfm_api_secret_here
LASTFM_USER=your_lastfm_username_here

# Spotify API Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback
# Obtained once via: python -m opener.cli.playlist authorize && ... token <code>
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here
# Set after the first `playlist write` so future runs refresh in place
SPOTIFY_PLAYLIST_ID=your_spotify_playlist_id_here

# Discovery playlist tuning (Phase 5)
# Artists with <= this many personal plays count as "under-explored"
PLAYLIST_UNDEREXPLORED_MAX_PLAYS=25
# Minimum share of the playlist that must be under-explored artists (0.0-1.0)
PLAYLIST_MIN_DISCOVERY_PCT=0.5

# Ticketmaster Discovery API (Phase 2 event ingest)
# Get a free API key at: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here
# Comma-separated Ticketmaster venue IDs for Portland venues (verified via /venues.json)
# Crystal Ballroom=rZ7HnEZaeyv, Wonder Ballroom=KovZpa9hBe, Roseland=KovZpap9re,
# Hawthorne=KovZpZAkn7IA, Aladdin=KovZpa3qfe, Revolution Hall=KovZpZAEkdIA,
# Doug Fir=KovZpZA1k1EA, Arlene Schnitzer=KovZpZAEkkJA (and 20 other verified IDs)
TICKETMASTER_VENUE_IDS=rZ7HnEZaeyv,KovZpa9hBe,KovZpap9re,KovZpZAkn7IA,KovZpa3qfe,KovZpZAEkdIA,KovZpZA1k1EA,KovZpZAEkkJA,KovZpa6MXe,KovZpZAJ67kA,KovZpZAEkdFA,KovZpZAIvlnA,KovZpZA1vlJA,KovZpZA1vFlA,KovZpZAFFEdA,Z7r9jZaA2K,KovZpap53e,Z7r9jZa7Ur,Z7r9jZaAf-,Z7r9jZakFN,Z7r9jZadc-,KovZ917AcZe,KovZpZAaIIaA,KovZ917Ai0C,KovZpZAEddeA,Z7r9jZa7sW,Z7r9jZaA1l,Z7r9jZad7E

# Affinity decay half-life in days (default: 56 = ~8 weeks)
# Increase for more weight on older plays, decrease for recency bias
AFFINITY_HALF_LIFE_DAYS=56

# General configuration
LOG_LEVEL=INFO
# Scoring strategy (exact-match-v1 or discovery-v1)
SCORING_VERSION=discovery-v1
